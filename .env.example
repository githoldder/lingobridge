# Frontend
VITE_API_BASE_URL="http://127.0.0.1:3001/api/v1"

# Backend
HOST="127.0.0.1"
PORT="3001"

# Future provider credentials. Never commit real values.
TENCENT_TTS_SECRET_ID=""
TENCENT_TTS_SECRET_KEY=""
JWT_SECRET="replace-with-local-demo-secret"

# TTS provider credentials for speech demo (SD-T01/SD-T02)
# Azure Speech — F0 tier provides 500K chars/month
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="eastus"
AZURE_SPEECH_TIER="F0"

# ElevenLabs — Free tier provides 10K chars/month
ELEVENLABS_API_KEY=""

# Volcengine / 豆包语音 (optional, for Chinese TTS alternative)
VOLC_ACCESS_KEY=""
VOLC_SECRET_KEY=""
VOLC_APP_ID=""

# Baidu Cloud TTS (optional, for Chinese TTS alternative)
BAIDU_TTS_APP_ID=""
BAIDU_TTS_API_KEY=""
BAIDU_TTS_SECRET_KEY=""
