# ==============================================================================
# LingoBridge Environment Configuration Example
# Keep this file clean of real production credentials.
# For matrix details, refer to: docs/03-testing-deployment/env-matrix.md
# ==============================================================================

# ------------------------------------------------------------------------------
# Frontend Configuration (Build-Time Variables)
# Note: Changing VITE_ variables requires running 'npm run build' again.
# ------------------------------------------------------------------------------
# Default fallback for local testing: "http://127.0.0.1:3001/api/v1"
# For Vercel hosting, leave empty or set to "/api/v1" to leverage proxy rewrites.
VITE_API_BASE_URL="http://127.0.0.1:3001/api/v1"

# ------------------------------------------------------------------------------
# Backend Configuration (Runtime Variables)
# ------------------------------------------------------------------------------
HOST="127.0.0.1"
PORT="3001"

# Encryption key used for signing JWT login session tokens
JWT_SECRET="replace-with-local-demo-secret"

# ------------------------------------------------------------------------------
# Optional Integration Providers
# Keep empty to use built-in offline mock fallbacks.
# ------------------------------------------------------------------------------
TENCENT_TTS_SECRET_ID=""
TENCENT_TTS_SECRET_KEY=""

# Azure Speech Integration (ASR & TTS Waveforms)
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="eastus"
AZURE_SPEECH_TIER="F0"

# ElevenLabs Integration
ELEVENLABS_API_KEY=""

# DeepL Translation Integration
DEEPL_API_KEY=""
