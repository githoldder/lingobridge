{
  "browser": {
    "launchOptions": {
      "headless": false,
      "args": [
        "--use-fake-ui-for-media-stream",
        "--use-fake-device-for-media-stream"
      ]
    },
    "contextOptions": {
      "viewport": { "width": 1440, "height": 900 },
      "permissions": ["camera", "microphone"]
    }
  }
}
